# Google Gemini (embeddings + chat)
GOOGLE_GENERATIVE_AI_API_KEY=

# PostgreSQL (Prisma) for chat history
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_ai?schema=public"

# Pinecone Vector DB
# Note: When using Gemini text-embedding-004, set index dimension to 768.
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=nexus-ai

# Optional: UploadThing for file uploads (required for upload UI)
# Get token from https://uploadthing.com/dashboard
# UPLOADTHING_TOKEN=

# Optional: Better Auth (when set, app requires sign-in)
# BETTER_AUTH_SECRET=   # generate with: npx auth@latest secret
# BETTER_AUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=    # Google OAuth client ID
# GOOGLE_CLIENT_SECRET= # Google OAuth client secret
