# Google Gemini (embeddings + grounded generation)
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768

# Supabase (Auth + Postgres + pgvector + Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for admin tasks if needed (optional in this app code path)
# SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for magic-link redirect callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional retrieval tuning
# RAG_CHUNKING=semantic
